# Database
DATABASE_URL=postgresql://devmetrics:devmetrics_secret@localhost:5432/devmetrics

# Redis
REDIS_URL=redis://localhost:6379

# JWT Secrets - CHANGE THESE IN PRODUCTION
JWT_SECRET=your_jwt_secret_key_min_32_chars_required
JWT_REFRESH_SECRET=your_jwt_refresh_secret_key_min_32_chars_required

# OpenAI
OPENAI_API_KEY=sk-your-openai-api-key

# Stripe
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
